FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV ZIG_VERSION=0.15.1

RUN apt-get update && apt-get install -y \
    curl \
    xz-utils \
    libsqlite3-dev \
    sqlite3 \
    && rm -rf /var/lib/apt/lists/*

# Download and extract Zig bootstrap (source that builds itself)
RUN curl -L "https://github.com/ziglang/zig/releases/download/${ZIG_VERSION}/zig-bootstrap-${ZIG_VERSION}.tar.xz" -o /tmp/zig.tar.xz && \
    tar -xf /tmp/zig.tar.xz -C /opt && \
    rm /tmp/zig.tar.xz

ENV PATH="/opt/zig-bootstrap-${ZIG_VERSION}:${PATH}"

WORKDIR /app

# Copy source
COPY . .

# Build (this builds zig from bootstrap source, producing linux/amd64 binary)
RUN /opt/zig-bootstrap-${ZIG_VERSION}/zig build -Dtarget=x86_64-linux-gnu

EXPOSE 5175

CMD ["/app/zig-out/bin/knot3bot", "--server", "--port", "5175", "--provider", "bailian"]
