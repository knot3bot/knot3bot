# knot3bot Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================

# OpenAI (GPT-4, GPT-3.5 Turbo)
OPENAI_API_KEY=

# Bailian (Alibaba Cloud Qwen)
BAILIAN_API_KEY=

# Kimi (Moonshot AI)
KIMI_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# ZAI (01.AI)
ZAI_API_KEY=

# Volcano (ByteDance)
VOLCANO_API_KEY=

# =============================================================================
# Server Configuration
# =============================================================================

# Port for HTTP server (default: 8080)
# PORT=8080

# Enable debug logging (default: false)
# DEBUG=false

# knot3bot workspace directory (default: /tmp)
# HERMES_WORKSPACE=/app/workspace
